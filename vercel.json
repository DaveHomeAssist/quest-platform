{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/mlb/shared/:path*", "destination": "/shared/:path*" },
    { "source": "/festival/shared/:path*", "destination": "/shared/:path*" },
    { "source": "/mlb", "destination": "/products/mlb/index.html" },
    { "source": "/mlb/", "destination": "/products/mlb/index.html" },
    { "source": "/mlb/:path*", "destination": "/products/mlb/:path*" },
    { "source": "/festival", "destination": "/products/festival/index.html" },
    { "source": "/festival/", "destination": "/products/festival/index.html" },
    { "source": "/festival/:path*", "destination": "/products/festival/:path*" },
    { "source": "/", "destination": "/products/mlb/index.html" }
  ],
  "headers": [
    {
      "source": "/shared/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
