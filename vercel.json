{
  "buildCommand": "sh build.sh",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/mlb/shared/:path*", "destination": "/shared/:path*" },
    { "source": "/festival/shared/:path*", "destination": "/shared/:path*" },
    { "source": "/mlb", "destination": "/mlb/index.html" },
    { "source": "/festival", "destination": "/festival/index.html" },
    { "source": "/", "destination": "/mlb/index.html" }
  ],
  "headers": [
    {
      "source": "/shared/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
