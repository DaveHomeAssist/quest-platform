{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/mlb/shared/(.*)", "destination": "/shared/$1" },
    { "source": "/festival/shared/(.*)", "destination": "/shared/$1" },
    { "source": "/mlb/(.*)", "destination": "/products/mlb/$1" },
    { "source": "/mlb", "destination": "/products/mlb/index.html" },
    { "source": "/festival/(.*)", "destination": "/products/festival/$1" },
    { "source": "/festival", "destination": "/products/festival/index.html" },
    { "source": "/", "destination": "/products/mlb/index.html" }
  ],
  "headers": [
    {
      "source": "/shared/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
